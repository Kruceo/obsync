{
  "name": "obsidian-s3-sync",
  "version": "1.0.0",
  "description": "Sync vault via S3/MinIO e sincroniza plugins community entre dispositivos.",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "version": "echo 'version placeholder'",
    "minio:up": "docker-compose up -d",
    "minio:down": "docker-compose down",
    "minio:logs": "docker-compose logs -f minio",
    "minio:setup": "bash scripts/setup-minio.sh"
  },
  "devDependencies": {
    "@types/node": "latest",
    "esbuild": "latest",
    "obsidian": "latest",
    "typescript": "latest"
  }
}
