{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "outDir": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "allowJs": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "importHelpers": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
